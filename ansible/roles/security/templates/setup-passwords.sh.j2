#!/bin/bash
# ============================================================================
# Script de configuration des mots de passe Elasticsearch built-in
# Exécuté sur es-master-01 après le démarrage du cluster
# ============================================================================
set -euo pipefail

ES_HOST="https://{{ ansible_host }}:9200"
ELASTIC_PASSWORD="{{ es_elastic_password }}"
CA_CERT="{{ es_certs_dir }}/ca.crt"

echo "=== Configuration des mots de passe Elasticsearch ==="

# Configurer kibana_system
echo "[1/3] Configuration du mot de passe kibana_system..."
curl -sk -u "elastic:${ELASTIC_PASSWORD}" \
  -X POST "${ES_HOST}/_security/user/kibana_system/_password" \
  -H "Content-Type: application/json" \
  --cacert "${CA_CERT}" \
  -d '{"password":"{{ es_kibana_password }}"}'
echo ""

# Créer l'utilisateur logstash_writer
echo "[2/3] Création de l'utilisateur logstash_writer..."
curl -sk -u "elastic:${ELASTIC_PASSWORD}" \
  -X POST "${ES_HOST}/_security/user/logstash_writer" \
  -H "Content-Type: application/json" \
  --cacert "${CA_CERT}" \
  -d '{
    "password":"{{ es_logstash_password }}",
    "roles":["logstash_writer_role"],
    "full_name":"Logstash Writer"
  }'
echo ""

# Créer l'utilisateur beats_writer
echo "[3/3] Création de l'utilisateur beats_writer..."
curl -sk -u "elastic:${ELASTIC_PASSWORD}" \
  -X POST "${ES_HOST}/_security/user/beats_writer" \
  -H "Content-Type: application/json" \
  --cacert "${CA_CERT}" \
  -d '{
    "password":"{{ es_beats_password }}",
    "roles":["beats_writer_role","kibana_admin"],
    "full_name":"Beats Writer"
  }'
echo ""

echo "=== Mots de passe configurés avec succès ==="
