# ============================================================================
# Configuration HAProxy - Générée par Ansible
# Load Balancing : Kibana (5601) + Elasticsearch (9200) + Stats (8404)
# ============================================================================

global
    log         /dev/log local0
    log         /dev/log local1 notice
    chroot      /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user        haproxy
    group       haproxy
    daemon
    maxconn     4096

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  redispatch
    retries 3
    timeout connect 5s
    timeout client  30s
    timeout server  30s
    timeout check   5s

# ============================================================================
# Page de statistiques HAProxy
# ============================================================================
listen stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats refresh 10s

# ============================================================================
# Frontend + Backend : Kibana (HTTPS passthrough)
# ============================================================================
frontend ft_kibana
    bind *:5601
    mode tcp
    option tcplog
    default_backend bk_kibana

backend bk_kibana
    mode tcp
    balance roundrobin
    option tcp-check
{% for host in groups['kibana'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:5601 check inter 5s rise 2 fall 3
{% endfor %}

# ============================================================================
# Frontend + Backend : Elasticsearch Coordinating Nodes (HTTPS passthrough)
# ============================================================================
frontend ft_elasticsearch
    bind *:9200
    mode tcp
    option tcplog
    default_backend bk_elasticsearch

backend bk_elasticsearch
    mode tcp
    balance roundrobin
    option tcp-check
{% for host in groups['es_coordinating'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:9200 check inter 5s rise 2 fall 3
{% endfor %}
